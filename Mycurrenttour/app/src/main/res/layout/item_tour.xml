<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:id="@+id/imgTourLogItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/centralvietnam" />

            <LinearLayout
                android:id="@+id/layoutAuthorInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/bg_author_tag"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgAuthorItem"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    android:src="@drawable/ic_person" />

                <TextView
                    android:id="@+id/txtAuthorNameItem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="8dp"
                    android:text="User Name"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtLogTourNameItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trip name"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLogDateItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Start date"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtLogExpenseItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total cost: $0"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnShareToPublicItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_share"
                android:gravity="center"
                android:padding="10dp"
                android:text="Share journey to public"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnAddTourItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_add"
                android:gravity="center"
                android:padding="10dp"
                android:text="+ Add this Tour"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnStartJourneyItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_share"
                android:backgroundTint="#4CAF50"
                android:gravity="center"
                android:padding="10dp"
                android:text="Start the journey"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnMemorableVideoItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_share"
                android:gravity="center"
                android:padding="10dp"
                android:text="Memorable video"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
