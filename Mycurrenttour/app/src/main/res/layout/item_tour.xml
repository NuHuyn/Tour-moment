<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgTourLogItem"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:src="@drawable/centralvietnam" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtLogTourNameItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trip name"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLogDateItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Start date"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtLogExpenseItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total cost: $0"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnShareToPublicItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_share"
                android:gravity="center"
                android:padding="10dp"
                android:text="Share journey to public"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnMemorableVideoItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="Memorable video"
                android:textColor="#424242" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>