<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#2E7D32"
        android:padding="20dp">

        <ImageView
            android:id="@+id/imgAvatarProfile"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_user_placeholder" />

        <TextView
            android:id="@+id/txtFullNameProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/imgAvatarProfile"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:text="Full Name"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginTop="-30dp"
        android:background="@drawable/ic_background_holder"
        android:layout_marginHorizontal="15dp">

        <TextView
            android:id="@+id/txtEmailProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp"
            android:text="Email: example@mail.com"
            android:textSize="16sp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <TextView
            android:id="@+id/txtPhoneProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp"
            android:text="Phone: 0912345678"
            android:textSize="16sp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <TextView
            android:id="@+id/txtRoleProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp"
            android:text="Role: Customer"
            android:textColor="#757575"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnEditProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:text="Chỉnh sửa hồ sơ"
        android:backgroundTint="#2E7D32"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:text="Đăng xuất"
        android:backgroundTint="#D32F2F"
        android:textColor="@android:color/white" />

</LinearLayout>